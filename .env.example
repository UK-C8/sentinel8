# ── Database ─────────────────────────────────────────────────────────────────
# Neon pooled URL — Next.js app + worker at runtime
DATABASE_URL=postgres://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon direct (non-pooled) URL — infra/migrate.sh only
DATABASE_URL_DIRECT=postgres://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Internal dogfood tenant ───────────────────────────────────────────────────
# UUID of Centr8's own tenant row in the tenants table
CENTR8_TENANT_ID=

# ── GitHub App ────────────────────────────────────────────────────────────────
# Create at github.com/settings/apps
# Callback URL: https://<your-domain>/api/connectors/github/callback
# Permissions: contents:read, metadata:read, security_events:read
GITHUB_APP_ID=
GITHUB_APP_SLUG=sentinel8          # the app's slug in the install URL
GITHUB_APP_PRIVATE_KEY=            # PEM contents, \n-escaped for single-line

# ── AWS connector ─────────────────────────────────────────────────────────────
# Sentinel8's own AWS account ID (printed in the CloudFormation trust policy)
AWS_ACCOUNT_ID=
# ExternalId in the trust policy — a stable secret per Sentinel8 deployment
SENTINEL8_EXTERNAL_ID=sentinel8-prod-change-me

# ── Vercel Cron auth ──────────────────────────────────────────────────────────
CRON_SECRET=change-me-random-string

# ── Claude API (usage-metered — see CLAUDE.md §2) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PostHog ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
